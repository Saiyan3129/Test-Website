# Copy to .env and fill in. Do not commit .env.

# --- Server -----------------------------------------------------------------
PORT=3000

# --- Google Sheets contact form --------------------------------------------
# Spreadsheet ID — long string in your sheet's URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Tab/worksheet name (the label at the bottom of the sheet)
GOOGLE_SHEETS_TAB=Contacts

# --- Service account credentials -------------------------------------------
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Sheets API on the project
# 3. Generate a JSON key — copy client_email and private_key from it
# 4. Share the spreadsheet with this service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the entire private key on one line, with literal `\n` for newlines.
# Wrap in double quotes so the loader keeps the value intact.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...your_key_here...\n-----END PRIVATE KEY-----\n"

# --- kie.ai (existing) ------------------------------------------------------
KIE_API_KEY=your_kie_ai_key_here
KIE_DEFAULT_MODEL=google/nano-banana