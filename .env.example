# Copy to .env and fill in. Do not commit .env.

# --- Server -----------------------------------------------------------------
PORT=3000

# --- Google Sheets contact form --------------------------------------------
# Spreadsheet ID — long string in your sheet's URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Tab/worksheet name (the label at the bottom of the sheet)
GOOGLE_SHEETS_TAB=Contacts

# --- Service account credentials -------------------------------------------
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Sheets API on the project
# 3. Generate a JSON key — copy client_email and private_key from it
# 4. Share the spreadsheet with this service account email (Editor access)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the entire private key on one line, with literal `\n` for newlines.
# Wrap in double quotes so the loader keeps the value intact.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...your_key_here...\n-----END PRIVATE KEY-----\n"

# --- Supabase (contact form primary store) ---------------------------------
# From Supabase Dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Use the service_role key (NOT the anon key) — it bypasses RLS so the
# Express backend can insert into contact_submissions. Keep this server-side
# only; never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: override the default table name
# SUPABASE_CONTACT_TABLE=contact_submissions

# --- Resend (confirmation email + reply-tracking webhook) ------------------
# Sending API key. A "Sending access" key is sufficient.
RESEND_API_KEY=re_your_resend_key_here

# From address. Use onboarding@resend.dev to start (no DNS setup required).
# Once you verify a custom domain in the Resend dashboard, switch this to
# something like hello@yourdomain.com.
RESEND_FROM=onboarding@resend.dev

# Where reply emails actually land. With a default From, this should be a
# real inbox you read. With a custom domain on Resend that has Inbound
# Emails configured, this can also be the address you've set as the
# inbound endpoint (the webhook then auto-marks reply_status = 'replied').
RESEND_REPLY_TO=you@yourdomain.com

# Inbound webhook signing secret. Copy from Resend Dashboard → Webhooks →
# your endpoint → "Signing Secret" (starts with "whsec_"). Without this,
# /api/resend-inbound returns 503 and reply auto-tracking is dormant.
# Requires Resend Inbound Emails to be set up on a verified domain.
RESEND_WEBHOOK_SECRET=

# Public origin used for unsubscribe links in drip emails. The drip script
# (scripts/send-followups.mjs) embeds ${SITE_URL}/api/unsubscribe?t=... in
# every email. Use your deployed hostname in production.
SITE_URL=http://localhost:3000

# --- Admin dashboard --------------------------------------------------------
# Password used at the dashboard login screen (/dashboard.html).
# Generate a strong one with:  node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
DASHBOARD_PASSWORD=

# Random secret used to sign the dashboard session cookie. Rotating this
# invalidates all existing sessions.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=

# --- kie.ai (existing) ------------------------------------------------------
KIE_API_KEY=your_kie_ai_key_here
KIE_DEFAULT_MODEL=google/nano-banana